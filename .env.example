# ── SCINEX / ChemX — API-ключи ──
# cp .env.example .env   и заполни значения. .env в .gitignore — в репо не попадёт.
# Подключается как shell-source:  set -a; source .env; set +a
# Формат строго KEY=value, без пробелов вокруг "=".

# ===== Обязательные (без них ядро не работает) =====
ANTHROPIC_API_KEY=        # Claude — vision-OCSR (структуры) + текстовый канал
DEEPSEEK_API_KEY=         # DeepSeek-V4 (api.deepseek.com) — оркестратор по умолчанию

# ===== Маршруты конвейера (реально используются в извлечении) =====
OPENROUTER_API_KEY=       # DeepSeek-V4-Pro verifier + fallback для deepseek-direct
GOOGLE_API_KEY=           # Gemini — критик (multi-agent review)
OPENAI_API_KEY=           # GPT — верификатор
MISTRAL_API_KEY=          # Mistral-OCR
MATHPIX_APP_ID=           # Mathpix-OCR (основной OCR-маршрут) — оба поля
MATHPIX_APP_KEY=          #   и идёт в паре с MATHPIX_APP_ID

# ===== Опционально =====
NOVITA_API_KEY=           # DeepSeek-Prover (prover-роль, нишевый)
LLM_PROXY=                # egress-прокси для frontier-API (Anthropic/OpenAI/Google) из РФ

# ── НЕ секреты: локальные пути/сервисы (для локальных OCSR-моделей; правь под машину) ──
# SCINEX_ORCH_MODEL=deepseek-direct
# MOLSCRIBE_PYTHON=/abs/.venv-molscribe/bin/python
# DECIMER_PYTHON=/abs/.venv-decimer/bin/python
# DECIMER_SEG_PYTHON=/abs/.venv-decimerseg/bin/python
# OPENCHEMIE_PYTHON=/abs/.venv-openchemie/bin/python
# GROBID_URL=http://localhost:8070
